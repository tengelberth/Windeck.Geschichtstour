<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Windeck.Geschichtstour.Mobile.Views.ToursListPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Touren">

    <!-- Zweck: Übersicht aller Touren mit Auswahlmöglichkeit. -->

    <ContentPage.Content>
        <Grid Padding="16">
            <RefreshView
                IsRefreshing="{Binding IsBusy,Mode=TwoWay}"
                Command="{Binding RefreshCommand}">
                <CollectionView
                    ItemsSource="{Binding Tours}"
                    SelectedItem="{Binding SelectedTour}"
                    SelectionMode="Single">

                    <CollectionView.Header>
                        <VerticalStackLayout Spacing="14" Margin="0,0,0,14">
                            <Border Padding="18"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#F4F7FB, Dark=#121820}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="24" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#22000000"
                                            Offset="0,4"
                                            Radius="12"
                                            Opacity="0.16" />
                                </Border.Shadow>

                                <VerticalStackLayout Spacing="8">
                                    <HorizontalStackLayout Spacing="8">
                                        <Image Source="mapblue.png"
                                               HeightRequest="20"
                                               VerticalOptions="Center" />
                                        <Label Text="Touren entdecken"
                                               FontSize="22"
                                               FontAttributes="Bold"
                                               VerticalOptions="Center" />
                                    </HorizontalStackLayout>

                                    <Label Text="Touren bündeln mehrere thematisch aufeinander abgestimmte Stationen. Wähle eine Tour aus und mach dich gleich auf den Weg."
                                           FontSize="14"
                                           LineBreakMode="WordWrap"
                                           Opacity="0.82" />
                                </VerticalStackLayout>
                            </Border>

                            <Label Text="Zum Aktualisieren nach unten ziehen."
                                   FontSize="12"
                                   Opacity="0.6" />

                            <Border IsVisible="{Binding IsBusy}"
                                    Padding="12"
                                    StrokeThickness="0"
                                    BackgroundColor="{AppThemeBinding Light=#EAF2FF, Dark=#172131}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="16" />
                                </Border.StrokeShape>

                                <VerticalStackLayout Spacing="2">
                                    <Label Text="{Binding LoadingMessage}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           HorizontalOptions="Center"
                                           HorizontalTextAlignment="Center"
                                           TextColor="{StaticResource Primary}" />
                                    <Label Text="{Binding LoadingElapsedText}"
                                           FontSize="11"
                                           HorizontalOptions="Center"
                                           Opacity="0.72" />
                                </VerticalStackLayout>
                            </Border>
                        </VerticalStackLayout>
                    </CollectionView.Header>

                    <CollectionView.EmptyView>
                        <VerticalStackLayout Padding="12,24"
                                             Spacing="8">
                            <Label Text="Noch keine Touren gefunden."
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   HorizontalTextAlignment="Center" />
                            <Label Text="Versuche es gleich noch einmal oder aktualisiere die Ansicht."
                                   FontSize="13"
                                   Opacity="0.75"
                                   HorizontalTextAlignment="Center" />
                        </VerticalStackLayout>
                    </CollectionView.EmptyView>

                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Style="{StaticResource CollectionItem}" Margin="0,0,0,12"
                                    Padding="16"
                                    Stroke="{AppThemeBinding Light=#D8E2F0, Dark=#243244}"
                                    StrokeThickness="1"
                                    BackgroundColor="Transparent">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>

                                <VerticalStackLayout Spacing="10">
                                    <Grid ColumnDefinitions="*,Auto"
                                          ColumnSpacing="8">
                                        <Label Text="{Binding Title, Mode=OneTime}"
                                               FontAttributes="Bold"
                                               FontSize="18"
                                               LineBreakMode="WordWrap" />
                                        <Image Grid.Column="1"
                                               Source="arrowrightwhite.png"
                                               HeightRequest="14"
                                               Rotation="180"
                                               VerticalOptions="Start"
                                               Opacity="0.45" />
                                    </Grid>

                                    <HorizontalStackLayout Spacing="8">
                                        <Border Padding="8,4"
                                                StrokeThickness="0"
                                                BackgroundColor="{AppThemeBinding Light=#EAF2FF, Dark=#172131}">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="12" />
                                            </Border.StrokeShape>
                                            <Label Text="{Binding Stops.Count, Mode=OneTime, StringFormat='Stationen: {0}'}"
                                                   FontSize="12"
                                                   FontAttributes="Bold"
                                                   TextColor="{StaticResource Primary}" />
                                        </Border>
                                    </HorizontalStackLayout>

                                    <Label Text="{Binding Description, Mode=OneTime}"
                                           FontSize="13"
                                           LineBreakMode="TailTruncation"
                                           MaxLines="4"
                                           Opacity="0.85" />
                                </VerticalStackLayout>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </RefreshView>
        </Grid>
    </ContentPage.Content>
</ContentPage>
