<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Windeck.Geschichtstour.Mobile.Views.HomePage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Geschichtstour Windeck">

    <!-- Zweck: Startseite mit klaren Einstiegen für Vor-Ort-Nutzung und Entdecken. -->

    <ScrollView>
        <VerticalStackLayout
            Padding="18"
            Spacing="16">

            <Border Padding="22"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#F4F7FB, Dark=#121820}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="28" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="#22000000"
                            Offset="0,4"
                            Radius="14"
                            Opacity="0.18" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="14">
                    <Image Source="windeckwappen.png"
                           HeightRequest="104"
                           HorizontalOptions="Center" />

                    <VerticalStackLayout Spacing="6">
                        <Label Text="Geschichte entdecken, direkt vor Ort"
                               FontSize="28"
                               FontAttributes="Bold"
                               HorizontalTextAlignment="Center" />

                        <Label Text="Erkunde historische Orte in Windeck mit Bildern, Hintergrundwissen und spannenden Geschichten – direkt draußen beim Spaziergang mit deinem Smartphone."
                               FontSize="14"
                               LineBreakMode="WordWrap"
                               HorizontalTextAlignment="Center"
                               Opacity="0.82" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>

            <Border Padding="16"
                    Stroke="{AppThemeBinding Light=#D8E2F0, Dark=#243244}"
                    StrokeThickness="1"
                    BackgroundColor="Transparent">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="10">
                    <Label Text="So funktioniert's"
                           FontSize="18"
                           FontAttributes="Bold" />

                    <Grid ColumnDefinitions="Auto,*"
                          RowDefinitions="Auto,Auto,Auto"
                          ColumnSpacing="10"
                          RowSpacing="10">
                        <Border Padding="0"
                                WidthRequest="28"
                                HeightRequest="28"
                                BackgroundColor="{AppThemeBinding Light=#EAF2FF, Dark=#172131}"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Label Text="1"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                        </Border>
                        <Label Grid.Column="1"
                               Text="Station vor Ort entdecken und Schild finden."
                               FontSize="13"
                               VerticalOptions="Center"
                               LineBreakMode="WordWrap" />

                        <Border Grid.Row="1"
                                Padding="0"
                                WidthRequest="28"
                                HeightRequest="28"
                                BackgroundColor="{AppThemeBinding Light=#EAF2FF, Dark=#172131}"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Label Text="2"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                        </Border>
                        <Label Grid.Row="1"
                               Grid.Column="1"
                               Text="QR-Code scannen oder Stationscode eingeben."
                               FontSize="13"
                               VerticalOptions="Center"
                               LineBreakMode="WordWrap" />

                        <Border Grid.Row="2"
                                Padding="0"
                                WidthRequest="28"
                                HeightRequest="28"
                                BackgroundColor="{AppThemeBinding Light=#EAF2FF, Dark=#172131}"
                                StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Label Text="3"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource Primary}" />
                        </Border>
                        <Label Grid.Row="2"
                               Grid.Column="1"
                               Text="Bilder, Texte &amp; Hintergründe zur Station entdecken."
                               FontSize="13"
                               VerticalOptions="Center"
                               LineBreakMode="WordWrap" />
                    </Grid>
                </VerticalStackLayout>
            </Border>

            <Border Padding="18"
                    StrokeThickness="0"
                    BackgroundColor="{AppThemeBinding Light=#EAF2FF, Dark=#172131}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="12">
                    <HorizontalStackLayout Spacing="8">
                        <Image Source="qrblue.png" HeightRequest="22" />
                        <Label Text="Vor Ort entdecken"
                               FontSize="19"
                               FontAttributes="Bold"
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <Label Text="An allen Stationen findest du einen QR-Code. Scanne diesen, um alle Inhalte zu der Station anzusehen."
                           FontSize="14"
                           LineBreakMode="WordWrap"
                           Opacity="0.82" />

                    <Button Text="QR-Code scannen"
                            ImageSource="qrwhite.png"
                            HeightRequest="44"
                            Command="{Binding ScanQrCommand}" />
                </VerticalStackLayout>
            </Border>

            <Border Padding="18"
                    Stroke="{AppThemeBinding Light=#D8E2F0, Dark=#243244}"
                    StrokeThickness="1"
                    BackgroundColor="Transparent">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="24" />
                </Border.StrokeShape>

                <VerticalStackLayout Spacing="12">
                    <Label Text="Station direkt öffnen"
                           FontSize="19"
                           FontAttributes="Bold" />

                    <Label Text="Wenn du bereits einen Stationscode hast, kannst du den Inhalt direkt aufrufen."
                           FontSize="14"
                           LineBreakMode="WordWrap"
                           Opacity="0.8" />

                    <Entry Placeholder="Code eingeben, z. B. KABELMETAL"
                           Text="{Binding Code}"
                           Keyboard="Text"
                           ClearButtonVisibility="WhileEditing" />

                    <Button Text="Station öffnen"
                            ImageSource="searchwhite.png"
                            HeightRequest="44"
                            Command="{Binding ShowStationCommand}" />
                </VerticalStackLayout>
            </Border>

            <VerticalStackLayout Spacing="10" Margin="0,4,0,0">
                <Label Text="Oder erst einmal entdecken"
                       FontSize="18"
                       FontAttributes="Bold" />

                <Grid ColumnDefinitions="*,*"
                      ColumnSpacing="12">
                    <Border Grid.Column="0"
                            Padding="16"
                            Stroke="{AppThemeBinding Light=#D8E2F0, Dark=#243244}"
                            StrokeThickness="1"
                            BackgroundColor="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="10">
                            <Image Source="markerblue.png"
                                   HeightRequest="20"
                                   HorizontalOptions="Start" />
                            <Label Text="Stationen entdecken"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   LineBreakMode="WordWrap" />
                            <Label Text="Finde Orte auf der Karte und entdecke Stationen in deiner Umgebung."
                                   FontSize="13"
                                   LineBreakMode="WordWrap"
                                   Opacity="0.8" />
                            <Button Text="Stationen"
                                    ImageSource="markerwhite.png"
                                    HeightRequest="42"
                                    Command="{Binding ShowAllStationsCommand}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Grid.Column="1"
                            Padding="16"
                            Stroke="{AppThemeBinding Light=#D8E2F0, Dark=#243244}"
                            StrokeThickness="1"
                            BackgroundColor="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="22" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="10">
                            <Image Source="mapblue.png"
                                   HeightRequest="20"
                                   HorizontalOptions="Start" />
                            <Label Text="Touren entdecken"
                                   FontSize="16"
                                   FontAttributes="Bold"
                                   LineBreakMode="WordWrap" />
                            <Label Text="Starte eine Tour mit mehreren aufeinander abgestimmten Stationen."
                                   FontSize="13"
                                   LineBreakMode="WordWrap"
                                   Opacity="0.8" />
                            <Button Text="Touren"
                                    ImageSource="mapwhite.png"
                                    HeightRequest="42"
                                    Command="{Binding ShowAllToursCommand}" />
                        </VerticalStackLayout>
                    </Border>
                </Grid>
            </VerticalStackLayout>

            <Label Text="Tipp: In Karte und Liste bekommst du nur einen kleinen Überblick über Station. Schaue vor Ort vorbei und scanne den QR-Code, um tiefer einzusteigen."
                   FontSize="12"
                   LineBreakMode="WordWrap"
                   Opacity="0.68" />

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>


