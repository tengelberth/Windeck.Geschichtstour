<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup
    x:Class="Windeck.Geschichtstour.Mobile.Views.MediaPreviewPopup"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:controls="clr-namespace:Windeck.Geschichtstour.Mobile.Controls"
    Background="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">

    <!-- Zweck: Popup zur vergrösserten Anzeige einzelner Medien. -->


    <Grid HorizontalOptions="Fill"
          VerticalOptions="Fill">

        <Grid Padding="10"
              HorizontalOptions="Fill"
              VerticalOptions="Fill">

            <controls:ZoomContainer>
                <Image x:Name="PreviewImage"
                       Aspect="AspectFit"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />
            </controls:ZoomContainer>

        </Grid>

        <Button Text="X"
                ZIndex="10"
                BackgroundColor="#66000000"
                TextColor="White"
                WidthRequest="44"
                HeightRequest="44"
                CornerRadius="22"
                HorizontalOptions="End"
                VerticalOptions="Start"
                Margin="0,36,10,0"
                Clicked="OnCloseClicked" />

        <VerticalStackLayout HorizontalOptions="Center"
                             VerticalOptions="End"
                             Spacing="8"
                             Margin="16,0,16,35">

            <Border x:Name="CaptionBorder"
                    BackgroundColor="#66000000"
                    StrokeThickness="0"
                    Padding="12,8"
                    IsVisible="False">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>

                <Label x:Name="CaptionLabel"
                       TextColor="White"
                       FontSize="13"
                       HorizontalTextAlignment="Center"
                       LineBreakMode="WordWrap"
                       MaxLines="3" />
            </Border>

            <Border BackgroundColor="#66000000"
                    StrokeThickness="0"
                    Padding="10,6"
                    HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="16" />
                </Border.StrokeShape>

                <Label Text="Doppeltippen zum Zoomen"
                       TextColor="White"
                       FontSize="12"
                       Opacity="0.9" />
            </Border>

        </VerticalStackLayout>

    </Grid>
</toolkit:Popup>
