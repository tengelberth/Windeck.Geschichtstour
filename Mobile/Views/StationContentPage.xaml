<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Windeck.Geschichtstour.Mobile.Views.StationContentPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml">

    <!-- Zweck: Detailseite einer Station inklusive Mediencarousel und Aktionen. -->

    <Shell.TitleView>
        <Grid ColumnDefinitions="*,Auto" Padding="0,0,20,0">
            <Label
                Text="{Binding Station.Title}"
                VerticalOptions="Center"
                FontAttributes="Bold"
                FontSize="18"
                LineBreakMode="TailTruncation"
                MaxLines="1" />

            <ImageButton
                IsVisible="{Binding HasStation}"
                Grid.Column="1"
                Source="{AppThemeBinding Light=shareblack.png, Dark=sharewhite.png}"
                MaximumHeightRequest="24"
                MaximumWidthRequest="24"
                BackgroundColor="Transparent"
                Command="{Binding ShareStationCommand}" />
        </Grid>
    </Shell.TitleView>

    <ContentPage.Content>
        <ScrollView>
            <VerticalStackLayout Padding="16" Spacing="12">

                <ActivityIndicator IsRunning="{Binding IsBusy}"
                                   IsVisible="{Binding IsBusy}"
                                   HorizontalOptions="Center" />

                <Label Text="Bitte warten. Station lädt..."
                       HorizontalOptions="Center"
                       IsVisible="{Binding IsBusy}" />

                <VerticalStackLayout IsVisible="{Binding HasStation}" Spacing="20">

                    <VerticalStackLayout Spacing="8"
                                         Margin="0,8,0,0"
                                         IsVisible="{Binding HasImages}">

                        <HorizontalStackLayout Spacing="5">
                            <Image Source="imgblue.png" HeightRequest="20" />
                            <Label Text="Medien"
                                   FontAttributes="Bold"
                                   FontSize="18" />
                        </HorizontalStackLayout>

                        <VerticalStackLayout Spacing="8">
                            <CarouselView BackgroundColor="Transparent"
                                          HeightRequest="310"
                                          ItemsSource="{Binding ImageMediaItems}"
                                          Position="{Binding MediaPosition, Mode=TwoWay}"
                                          Loop="False"
                                          IsSwipeEnabled="True"
                                          PeekAreaInsets="0"
                                          HorizontalOptions="Fill"
                                          VerticalOptions="Start">

                                <CarouselView.ItemTemplate>
                                    <DataTemplate>
                                        <VerticalStackLayout Spacing="8" BackgroundColor="Transparent">
                                            <Border StrokeThickness="0"
                                                    Padding="0"
                                                    Margin="5,0,5,0"
                                                    HeightRequest="280">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="18" />
                                                </Border.StrokeShape>

                                                <Grid>
                                                    <Image Source="{Binding FullUrl, Mode=OneTime}"
                                                           Aspect="AspectFill"
                                                           BackgroundColor="Transparent">
                                                        <Image.GestureRecognizers>
                                                            <TapGestureRecognizer
                                                                Command="{Binding Source={RelativeSource AncestorType={x:Type ContentPage}}, Path=BindingContext.OpenMediaOverlayCommand}"
                                                                CommandParameter="{Binding .}" />
                                                        </Image.GestureRecognizers>
                                                    </Image>
                                                </Grid>
                                            </Border>

                                            <Label Text="{Binding Caption, Mode=OneTime}"
                                                   FontSize="12"
                                                   LineBreakMode="WordWrap" />
                                        </VerticalStackLayout>
                                    </DataTemplate>
                                </CarouselView.ItemTemplate>
                            </CarouselView>

                            <Grid ColumnDefinitions="Auto,*"
                                  IsVisible="{Binding HasMultipleImages}">
                                <Border Padding="8,3"
                                        StrokeThickness="0"
                                        BackgroundColor="{AppThemeBinding Light=#F0F4FA, Dark=#1F2733}"
                                        HorizontalOptions="Start">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="12" />
                                    </Border.StrokeShape>
                                    <Label Text="{Binding CurrentMediaIndicator}"
                                           FontSize="11"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource Primary}" />
                                </Border>

                                <Label Grid.Column="1"
                                       Text="Zum Wechseln wischen"
                                       FontSize="11"
                                       VerticalOptions="Center"
                                       HorizontalOptions="End"
                                       Opacity="0.7" />
                            </Grid>
                        </VerticalStackLayout>
                    </VerticalStackLayout>

                    <Border Padding="14"
                            Stroke="{AppThemeBinding Light=#D8E2F0, Dark=#243244}"
                            StrokeThickness="1"
                            BackgroundColor="Transparent">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18" />
                        </Border.StrokeShape>

                        <VerticalStackLayout Spacing="10">
                            <HorizontalStackLayout Spacing="8">
                                <Image Source="{AppThemeBinding Light=shareblack.png, Dark=sharewhite.png}"
                                       HeightRequest="18"
                                       VerticalOptions="Center" />
                                <Label Text="Station teilen"
                                       FontAttributes="Bold"
                                       FontSize="16"
                                       VerticalOptions="Center" />
                            </HorizontalStackLayout>

                            <Label Text="Hat dir diese Station gefallen? Teile sie direkt mit anderen und verschicke den Link per Nachricht oder Mail!"
                                   FontSize="13"
                                   LineBreakMode="WordWrap"
                                   Opacity="0.82" />

                            <Button Text="Station teilen"
                                    ImageSource="sharewhite.png"
                                    HeightRequest="41"
                                    Command="{Binding ShareStationCommand}" />
                        </VerticalStackLayout>
                    </Border>

                    <Border Padding="10"
                            BackgroundColor="Transparent"
                            Stroke="{StaticResource Primary}"
                            StrokeThickness="1"
                            VerticalOptions="Center">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="10" />
                        </Border.StrokeShape>
                        <Border.Shadow>
                            <Shadow Brush="#33000000"
                                    Offset="0,2"
                                    Radius="8"
                                    Opacity="0.25" />
                        </Border.Shadow>
                        <VerticalStackLayout Spacing="2">
                            <HorizontalStackLayout Spacing="2">
                                <Image Source="markerblue.png" HeightRequest="20" />

                                <Label Text="Adresse"
                                       FontAttributes="Bold"
                                       FontSize="16"
                                       IsVisible="{Binding Station.Street}" />
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="3">
                                <Label Text="{Binding Station.Street}"
                                       IsVisible="{Binding Station.Street}" />
                                <Label Text="{Binding Station.HouseNumber}"
                                       IsVisible="{Binding Station.HouseNumber}" />
                            </HorizontalStackLayout>

                            <HorizontalStackLayout Spacing="3">
                                <Label Text="{Binding Station.ZipCode}"
                                       IsVisible="{Binding Station.ZipCode}" />
                                <Label Text="{Binding Station.City}"
                                       IsVisible="{Binding Station.City}" />
                            </HorizontalStackLayout>
                            <Button Text="In Google Maps öffnen" Margin="0,10,0,0" ImageSource="naviwhite.png" HeightRequest="41"
                                    Command="{Binding OpenInMapsCommand}" />
                            <Button Text="In Komoot Tour planen" Margin="0,5,0,0" ImageSource="trekkingwhite.png" HeightRequest="41"
                                    Command="{Binding OpenInKomootCommand}" />
                        </VerticalStackLayout>
                    </Border>

                    <VerticalStackLayout Spacing="8"
                                         IsVisible="{Binding HasLongDescription}">
                        <WebView x:Name="DescriptionWebView"
                                 HeightRequest="{Binding LongDescriptionHeight}"
                                 BackgroundColor="Transparent"
                                 Navigating="DescriptionWebView_Navigating">
                            <WebView.Source>
                                <HtmlWebViewSource Html="{Binding LongDescriptionHtml}" />
                            </WebView.Source>
                        </WebView>

                        <Button Text="Beschreibung neu laden"
                                Command="{Binding ReloadDescriptionCommand}"
                                HeightRequest="38"
                                HorizontalOptions="End"
                                BackgroundColor="{AppThemeBinding Light=#F0F4FA, Dark=#1F2733}"
                                TextColor="{StaticResource Primary}" />
                    </VerticalStackLayout>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </ScrollView>
    </ContentPage.Content>
</ContentPage>

